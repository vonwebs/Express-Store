{
  "expo": {
    "name": "Express-Store",
    "slug": "Express-Store",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/express.png",
    "userInterfaceStyle": "light",
    "scheme": "expressstore",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/express.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.stephenj3.expressstore",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/express.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.stephenj3.expressstore",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/express.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#ffffff",
          "androidMode": "default",
          "androidCollapsedTitle": "Express Store"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "238b52b9-6a73-438c-8969-a9c8efd2d4ca"
      },
      "firebaseApiKey": "AIzaSyBqrV1yGWsLj17JXFwfIWRP-sqX6hp8vLk",
      "firebaseAuthDomain": "expressmart-7d550.firebaseapp.com",
      "firebaseProjectId": "expressmart-7d550",
      "firebaseStorageBucket": "expressmart-7d550.firebasestorage.app",
      "firebaseMessagingSenderId": "499123636329",
      "firebaseAppId": "1:499123636329:web:9a96c3d4b6ed11c3f57af8",
      "firebaseVapidKey": "YOUR_VAPID_KEY"
    },
    "owner": "stephen_j"
  }
}
